# Copy to .env and fill in (or just export these in your shell).
# Loaded by pipeline/config.py via python-dotenv.

# Cohere API key — stage 04 embeds each film with embed-v4.0, and stage 06
# (Toponymy) embeds candidate region-name keyphrases. Use a PRODUCTION key:
# trial keys are heavily rate-limited.
CO_API_KEY=

# Anthropic API key — stage 06 uses Claude to name the topic regions.
ANTHROPIC_API_KEY=

# TMDB API key — stage 02 matches each film against The Movie Database for
# synopsis gap-fill, cast/director, and poster images. Free: create an account
# at themoviedb.org, then Settings -> API. Either the short v3 "API Key" or the
# long v4 "Read Access Token" works here.
TMDB_API_KEY=
